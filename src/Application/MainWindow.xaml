<Window x:Class="ProcessingApp.Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessingApp.Application"
        mc:Ignorable="d"
        Title="Обработка и экспорт данных" Height="650" Width="700" MinHeight="650" MinWidth="700">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="1. Импорт исходных данных" Grid.Row="0" Margin="0,0,0,15" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Name="Choose_File_Btn" Content="Выбрать и загрузить CSV файл" Padding="10,5" Click="Choose_File_Btn_Click"/>
               
            </StackPanel>
        </GroupBox>

        <GroupBox Header="2. Фильтрация данных для экспорта (Любая комбинация)" Grid.Row="1" Margin="0,0,0,15" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <UniformGrid Columns="2" VerticalAlignment="Top">
                    <StackPanel Margin="5">
                        <Label Content="Фамилия:"/>
                        <TextBox Name="LastNameTextBox" Padding="3"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <Label Content="Имя:"/>
                        <TextBox Name="FirstNameTextBox" Padding="3"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <Label Content="Отчество:"/>
                        <TextBox Name="SurNameTextBox" Padding="3"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <Label Content="Дата записи:"/>
                        <DatePicker Name="MyDatePicker"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <Label Content="Город:"/>
                        <TextBox Name="CityTextBox" Padding="3"/>
                    </StackPanel>

                    <StackPanel Margin="5">
                        <Label Content="Страна:"/>
                        <TextBox Name="CountryTextBox" Padding="3"/>
                    </StackPanel>
                </UniformGrid>
            </ScrollViewer>
        </GroupBox>

        <GroupBox Header="3. Предварительный просмотр данных" Grid.Row="2" Margin="0,0,0,15" Padding="5">
            <DataGrid Name="MyDataGrid" AutoGenerateColumns="True" IsReadOnly="True" GridLinesVisibility="Horizontal" Background="White"/>
        </GroupBox>


        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Grid.ColumnSpan="2" Margin="0,0,417,0">
                <TextBlock Name="StatusLabel" Text="Готов к работе" FontWeight="SemiBold" Foreground="DarkGreen" Width="252" Height="36"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Name="CheckFilterBtn" Content="Найти в базе (Проверка)" Margin="0,0,10,0" Padding="15,7" Background="#DDEBF7" Click="CheckFilterBtn_Click"/>
                <Button Name="ExportExcelBtn" Content="Экспорт в Excel" Margin="0,0,10,0" Padding="15,7" Background="#E2F0D9" Click="ExportExcelBtn_Click"/>
                <Button Name="ExportXmlBtn" Content="Экспорт в XML" Padding="15,7" Background="#FFF2CC" Click="ExportXmlBtn_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
